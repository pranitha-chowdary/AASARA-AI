# ── AASARA Frontend – required env vars ─────────────────────────────────────
#
# Copy this file to .env.local (dev) or set these in the Netlify dashboard
# under Site → Environment variables.
#
# The backend URL after you deploy to Railway / Render / Fly.io:
VITE_API_URL=https://your-backend.railway.app

# Optional: if ML engine is on a separate domain
# VITE_ML_ENGINE_URL=https://your-ml-engine.railway.app
