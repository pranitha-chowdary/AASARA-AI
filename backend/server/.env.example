# ── AASARA Backend – required env vars ──────────────────────────────────────
#
# Copy this to backend/server/.env  OR  set these in Railway / Render dashboard
#
PORT=5001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_long_random_string

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Brevo / Sendinblue (email)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=support@aasara.ai
BREVO_SENDER_NAME=AASARA Support

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ML Engine (Railway internal URL or public URL)
ML_ENGINE_URL=https://your-ml-engine.railway.app

# Optional: Newsdata.io for live social triggers
# NEWSDATA_API_KEY=pub_xxxxxxxxxxxxxxxxxxxx

# Optional: CORS extra origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-custom-domain.com

# Optional: Skip 5-day eligibility for testing
# BYPASS_ELIGIBILITY_CHECK=true

# Optional: Blockchain (Sepolia)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/xxxxxxxx
# DEPLOYER_PRIVATE_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxaaaa
# AASARA_CONTRACT_ADDRESS=0x...
