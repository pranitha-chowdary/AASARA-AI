# ── AASARA ML Engine – required env vars ────────────────────────────────────
#
# Copy to backend/ml_engine/.env  OR  set in Railway / Render dashboard
#
# Port is set automatically by Railway via $PORT; no need to set here.

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Newsdata.io for live social-trigger news scanning
# NEWSDATA_API_KEY=pub_xxxxxxxxxxxxxxxxxxxx
